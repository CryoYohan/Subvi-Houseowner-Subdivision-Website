<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Landing - House Subdivision</title>
	<link href="~/css/landing.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.3.5/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="~/css/output.css">
    <link rel="stylesheet" href="~/css/landing.css">
</head>
<body class="font-[Poppins]">
    <header class="px-10 py-5 shadow-md bg-white header">
        <nav class="flex items-center justify-between">
            <!-- Logo -->
            <a href="#" class="block">
                <img src="~/images/subvi-logo.png" class="h-12" alt="Subvi Logo">
            </a>
            <!-- Buttons -->
            <div class="flex space-x-10" style="margin-right: 80px;">
                <button href="#" class="text-black-800 text-lg font-semibold nav-item border-b-2 border-blue-800" style="font-family: Tahoma, sans-serif; margin-right: 50px;">Home</button>
                <button href="#" class="text-black-800 text-lg font-semibold nav-item " style="font-family: Tahoma, sans-serif; margin-right: 50px;">About Us</button>
                <button href="#" class="text-black-800 text-lg font-semibold nav-item " style="font-family: Tahoma, sans-serif; margin-right: 50px;">Contacts</button>
                <button onclick="openLoginModal()" class="block bg-[#1E3A8A] text-white py-2 px-8 rounded-lg text-center nav-button shadow-md" style="font-family: Tahoma, sans-serif; margin-right: 50px;">Log In</button>
            </div>
        </nav>
    </header>

    <!-- Login Modal -->
    <div id="login-modal" class="hidden fixed inset-0 flex items-center justify-center bg-gray-800 bg-opacity-50">
        <div class="bg-white p-6 rounded-lg shadow-lg w-96">
            <div class="flex justify-end">
                <button type="button" onclick="closeLoginModal()" class="text-black-50 text-5xl px-4 py-2 rounded">&times;</button>
            </div>
            <h2 class="text-xl font-bold text-center mb-4">Login Now</h2>
            <form id="login-form">
                <label class="block mb-2">Email</label>
                <input type="email" id="login-email" class="w-full p-2 border rounded mb-3" required>

                <label class="block mb-2">Password</label>
                <input type="password" id="login-password" class="w-full p-2 border rounded mb-3" required>

                <div class="flex justify-between">
                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Login</button>
                </div>
            </form>

            <div class="w-full border-t border-gray-300 mt-4"></div>

            <!-- Google Sign-In Section -->
            <div class="flex flex-col items-center space-y-4 mt-4">
                <p class="text-gray-500">Or log in with Google</p>

                <div id="g_id_onload"
                     data-client_id="556953627417-j7ck52oo8s1ciavni7i5hrn5rbko7jhu.apps.googleusercontent.com"
                     data-callback="handleGoogleSignIn"
                     data-auto_prompt="false">
                </div>
                <div class="g_id_signin" data-type="standard"></div>
            </div>
        </div>
    </div>


    <!-- Sign Up Modal -->
    <div id="signup-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center">
        <div class="bg-white p-8 rounded-lg shadow-lg w-1/3">
            <h2 class="text-2xl font-bold text-blue-800 mb-4">Sign Up</h2>

            <!-- Google Sign-Up Button -->
            <div class="flex flex-col items-center space-y-4">
                <div id="g_id_onload"
                     data-client_id="556953627417-j7ck52oo8s1ciavni7i5hrn5rbko7jhu.apps.googleusercontent.com"
                     data-callback="handleGoogleSignIn"
                     data-auto_prompt="false">
                </div>
                <div class="g_id_signin" data-type="standard"></div>

                <p class="text-gray-500">OR</p>

                <!-- Divider -->
                <div class="w-full border-t border-gray-300 mt-4"></div>
            </div>

            <form id="signup-form">
                <div class="mb-4">
                    <label class="block text-gray-700">First Name</label>
                    <input type="text" id="firstname" class="w-full border rounded-lg px-3 py-2" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700">Last Name</label>
                    <input type="text" id="lastname" class="w-full border rounded-lg px-3 py-2" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700">Email</label>
                    <input type="email" id="email" class="w-full border rounded-lg px-3 py-2" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700">Password</label>
                    <input type="password" id="password" class="w-full border rounded-lg px-3 py-2" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700">Address</label>
                    <input type="text" id="address" class="w-full border rounded-lg px-3 py-2">
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700">Phone Number</label>
                    <input type="text" id="phonum" class="w-full border rounded-lg px-3 py-2">
                </div>
                <div class="flex justify-end space-x-4">
                    <button type="button" onclick="closeSignupModal()" class="bg-gray-500 text-white px-4 py-2 rounded-lg">Cancel</button>
                    <button type="submit" class="bg-blue-800 text-white px-4 py-2 rounded-lg">Sign Up</button>
                </div>
            </form>
        </div>
    </div>

    <main class="flex items-center justify-between h-screen px-6">
    <!-- Left: Text Section -->
    <div class="flex flex-col">
        <h1 class="text-5xl mb-2" style="margin-left: 50px; font-size: 70px; font-family: Tahoma, sans-serif;">
            Welcome to
            <span style="font-weight: bold; display: inline; color: #1E3A8A;">Subvi</span>
            <p style="margin-top: 10px;">Smart Living in a</p>
            <p style="margin-top: 10px;">Thriving Community</p>
        </h1>

        <p id="changing-text" class="text-gray-600 max-w-2xl" style="font-size: 20px; margin-left: 50px; font-family: Tahoma, sans-serif;"></p>
        
        <button onclick="openSignupModal()" class="mt-6 px-8 py-3 bg-[#1E3A8A] text-white font-semibold rounded-lg shadow-md hover-animate" style="width: 250px; height: 50px; margin-top: 50px; margin-left: 50px;">
            Join Us Now!
        </button>
    </div>

    <!-- Right: Image Section -->
    <div class="flex justify-end">
        <img src="~/images/111.png" style="width: 1100px; height: 700px;">
    </div>
</main>

<!-- New Section Below Main -->
    <section class="text-white py-20 px-10" style="margin-top: -50px; margin-left: 140px;">
        <div class="container mx-auto text-center relative"
             style="width: 2200px; height: 750px; background: url('/images/222.png') no-repeat center center; background-size: cover; position: relative; border-radius: 30px;">

            <!-- Centering the images inside the background -->
            <div class="absolute top-0 left-0 w-full h-full flex justify-center items-center" style="z-index: 2; display: flex; gap: 200px;">
                <!-- First image -->
                <div class="w3-container" style="margin-top: 330px;">
                    <img src="~/images/333.png" style="width: 200px; height: auto; object-fit: contain;">
                </div>
                <!-- Second image -->
                <div class="w3-container relative" style="margin-top: 330px;">
                    <img src="~/images/444.png" style="width: 200px; height: auto; object-fit: contain;">
                </div>
                <!-- Third image -->
                <div class="w3-container relative" style="margin-top: 330px;">
                    <img src="~/images/555.png" style="width: 200px; height: auto; object-fit: contain;">
                </div>
            </div>
            <div class="w3-container relative">
                <!-- Image -->
                <img src="/images/777.png" style="width: 900px; height: 200px; margin-left: 300px; margin-top: 100px;">

                <!-- Button container (absolute positioning inside the image) -->
                <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); display: flex; gap: 200px; margin-top: 380px;">
                    <button class="hover-animate" style="padding: 10px 20px; font-size: 20px; background-color: #1E3A8A; font-family: Tahoma, sans-serif; color: white; border: none; border-radius: 20px; cursor: pointer; height: 70px; width: 180px;">
                        Inquire now!
                    </button>
                    <button class="hover-animate" style="padding: 10px 20px; font-size: 20px; background-color: #1E3A8A; font-family: Tahoma, sans-serif; color: white; border: none; border-radius: 20px; cursor: pointer; width: 180px;">
                        Apply now
                    </button>
                </div>
            </div>

        </div>
    </section>

        

    <main class="flex flex-col items-center justify-center h-screen text-center px-6">
        @RenderBody()
    </main>




    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script src="https://apis.google.com/js/platform.js" async defer></script>
    <script src="https://cdn.jsdelivr.net/npm/jwt-decode@3.1.2/build/jwt-decode.min.js"></script>
    <script src="~/js/typingeffect.js"></script>
    <script src="~/js/signup.js"></script>
    <script src="~/js/login.js"></script>
</body>
</html>
